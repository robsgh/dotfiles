#!/bin/bash
set -euo pipefail

NAS_USER="${NAS_USER:-$USER}"
NAS_HOST="${NAS_HOST:-fixme}"
NAS_BASE="${NAS_BASEPATH}/$NAS_USER/homedir-backups"
SSH_KEY="${SSH_KEY:-notakey}"

# number of snapshots to keep on the NAS
KEEP_LATEST=7
# how many rsyncs to do in parallel (10 is the default concurrent SSH attempts allowed by sshd in debian)
PARALLEL=${PARALLEL:-10}
# file with paths to exclude from backup (caches, usually)
EXCLUDES="$HOME/.config/backup-to-nas/excludes"

DATE="$(date -u +%FT%H%M%SZ)"

echo "====================================="
echo "           Starting backup"
echo "Remote User: $NAS_USER"
echo "Remote Host: $NAS_HOST"
echo "Date:        $DATE"
echo "Remote Dest: $NAS_BASE/$DATE"
echo "Keep Latest: $KEEP_LATEST"
echo "Parallel:    $PARALLEL"
echo "Excludes:    $EXCLUDES"
echo "=====================================\n\n"


log() { echo "backup-to-nas: $*"; }

# Find the most recent snapper timeline snapshot for home
log "event=find_snapshot"
SNAP_NUM=$(snapper --csvout -c home list --columns number,cleanup | awk -F, '$2 == "timeline" {print $1}' | tail -1)

if [[ -z "$SNAP_NUM" ]]; then
  log "event=abort reason=no_timeline_snapshot"
  exit 1
fi

SNAP="/home/.snapshots/$SNAP_NUM/snapshot"

if [[ ! -d "$SNAP" ]]; then
  log "event=abort reason=snapshot_dir_missing path=$SNAP"
  exit 1
fi

log "event=start snapshot=$SNAP_NUM dest=$NAS_BASE/$DATE"

log "event=find_prev_snapshot"
PREV=$(ssh -i "$SSH_KEY" $NAS_USER@$NAS_HOST "ls -d $NAS_BASE/????-??-??T??????Z 2>/dev/null | tail -1")
if [[ -z "$PREV" ]]; then
  log "event=no_prev_snapshot";
else
  log "event=found_prev_snapshot name=$PREV";
fi

run_rsync() {
  local entry="$1"
  log "event=rsync_start dir=$SNAP/$entry"

  # Strip the entry prefix from path-based patterns so they match correctly
  # when this subdirectory is used as the rsync transfer root.
  # e.g. ".config/chromium/Cache/" becomes "chromium/Cache/" when entry=".config"
  local tmpexcl
  tmpexcl=$(mktemp)
  local escaped_entry
  escaped_entry=$(printf '%s' "$entry" | sed 's/[.^$*[\]/\\&/g')
  sed "s|^${escaped_entry}/||" "$EXCLUDES" > "$tmpexcl"

  rsync -avzx \
    ${PREV:+--link-dest="$PREV/$entry"} \
    --exclude-from="$tmpexcl" \
    -e "ssh -i $SSH_KEY" \
    "$SNAP/$entry/" \
    "$NAS_USER@$NAS_HOST:$NAS_BASE/$DATE/$entry/"

  rm -f "$tmpexcl"
  log "event=rsync_done dir=$SNAP/$entry"
}
export -f run_rsync log
export PREV SNAP NAS_USER NAS_HOST NAS_BASE DATE HOME EXCLUDES

# The snapshot contains one dir (the homedir). Split by its contents.
INNER=$(find "$SNAP" -maxdepth 1 -mindepth 1 -type d ! -name '.snapshots' -printf '%f\n')
export INNER

# mkdir that before we start
log "event=mkdir_homedir snapshot=$SNAP_NUM dest=$NAS_BASE/$DATE/$INNER"
ssh -i "$SSH_KEY" $NAS_USER@$NAS_HOST "mkdir -p $NAS_BASE/$DATE/$INNER"

BACKUP_TIMESTAMP_PATH="$NAS_BASE/$DATE/$INNER/000-backup-timestamp"
log "event=write_timestamp dest=$BACKUP_TIMESTAMP_PATH"
ssh -i "$SSH_KEY" $NAS_USER@$NAS_HOST "echo 'Backup from $DATE' > $BACKUP_TIMESTAMP_PATH"

# Sync root-level files (dotfiles etc) in a single non-recursive pass
log "event=rsync_homedir_start"
rsync -avzx --no-recursive \
  ${PREV:+--link-dest="$PREV/$INNER/"} \
  --exclude-from="$EXCLUDES" \
  -e "ssh -i $SSH_KEY" \
  "$SNAP/$INNER/" \
  "$NAS_USER@$NAS_HOST:$NAS_BASE/$DATE/$INNER/"
log "event=rsync_homedir_done"

# Sync subdirectories in parallel
log "event=sync_homedir_rec_start"
find "$SNAP/$INNER" -maxdepth 1 -mindepth 1 -type d -printf '%f\0' \
  | xargs -0 -P"$PARALLEL" -I{} bash -c 'run_rsync "$@"' _ "$INNER/{}"
log "event=sync_homedir_rec_done"

log "event=prune keeping=$KEEP_LATEST"

ssh -i "$SSH_KEY" $NAS_USER@$NAS_HOST \
  "ls -d $NAS_BASE/????-??-??T??????Z 2>/dev/null | head -n -$KEEP_LATEST | xargs -r rm -rf"

log "event=done"
