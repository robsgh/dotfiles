# backup-to-nas exclude list
# rsync filter rules: https://man.archlinux.org/man/rsync.1#FILTER_RULES

# Build artifacts & package caches
node_modules/
.cargo/registry/
.cargo/git/
target/
__pycache__/
.gradle/
.m2/
venv/
dist/
.astro/

# App caches
.cache/
.local/share/Trash/
.npm/_cacache/
.nv/

# Rust toolchains (large, restored with rustup)
.rustup/toolchains/
.rustup/downloads/
.rustup/tmp/

# Steam — exclude game files but keep saves and config
.local/share/Steam/steamapps/common/
.local/share/Steam/steamapps/downloading/
.local/share/Steam/steamapps/temp/
.local/share/Steam/steamapps/shadercache/
.local/share/Steam/logs/

# Wine — exclude installed apps, keep user data
.wine/drive_c/Program Files/
.wine/drive_c/Program Files (x86)/

# Factorio temp
.factorio/temp/

# Flatpak runtimes (redownloadable)
.local/share/flatpak/

# Wine Windows system files (recreated by wine)
.wine/drive_c/windows/

# Electron app caches (chromium, discord, signal, unityhub, spotify)
.config/chromium/GrShaderCache/
.config/chromium/ShaderCache/
.config/chromium/GraphiteDawnCache/
.config/discord/Cache/
.config/discord/Code Cache/
.config/discord/GPUCache/
.config/discord/DawnGraphiteCache/
.config/discord/DawnWebGPUCache/
.config/Signal/Cache/
.config/Signal/Code Cache/
.config/Signal/GPUCache/
.config/Signal/DawnGraphiteCache/
.config/Signal/DawnWebGPUCache/
.config/unityhub/Cache/
.config/unityhub/Code Cache/
.config/unityhub/GPUCache/
.config/unityhub/DawnGraphiteCache/
.config/unityhub/DawnWebGPUCache/

# OBS ephemeral data
.config/obs-studio/logs/
.config/obs-studio/profiler_data/

# Claude CLI ephemeral data
.claude/cache/
.claude/session-env/
.claude/file-history/

# Virtual machines & containers
*.vmdk
*.vdi
*.qcow2
*.img
