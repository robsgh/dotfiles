#!/bin/bash

# Desktop:summary=Launch an app or focus an existing window matching a pattern
# Desktop:args=<window-pattern> [launch-command...]

if (($# == 0)); then
  echo "Usage: $(basename "$0") <window-pattern> [launch-command...]" >&2
  exit 1
fi

WINDOW_PATTERN="$1"
shift
WINDOW_ADDRESS=$(hyprctl clients -j | jq -r --arg p "$WINDOW_PATTERN" '.[]|select((.class|test("\\b" + $p + "\\b";"i")) or (.title|test("\\b" + $p + "\\b";"i")))|.address' | head -n1)

if [[ -n $WINDOW_ADDRESS ]]; then
  hyprctl dispatch focuswindow "address:$WINDOW_ADDRESS"
elif (($# > 0)); then
  exec setsid "$@"
else
  exec setsid uwsm-app -- "$WINDOW_PATTERN"
fi
