#!/bin/bash

# Ensure sibling rob-* helpers resolve when launched by Hyprland without shell PATH updates.
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
export PATH="$script_dir:$PATH"

# Desktop:summary=Return success if the focused Hyprland monitor is an Apple display.

hyprctl monitors -j | jq -e '.[] | select(.focused == true) | select(.make == "Apple Computer Inc" and (.model | test("StudioDisplay|ProDisplayXDR|Studio XDR")))' >/dev/null
