#!/bin/bash

# Ensure sibling rob-* helpers resolve when launched by Hyprland without shell PATH updates.
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
export PATH="$script_dir:$PATH"

# Desktop:summary=Toggle permanent Hyprland flags by copying them into a directory that's sourced entirely.
# Desktop:args=[--enabled-notification <text>] [--disabled-notification <text>] <flag-name>

ENABLED_NOTIFICATION=""
DISABLED_NOTIFICATION=""

while [[ $# -gt 1 ]]; do
  case $1 in
    --enabled-notification) ENABLED_NOTIFICATION="$2"; shift 2 ;;
    --disabled-notification) DISABLED_NOTIFICATION="$2"; shift 2 ;;
    *) break ;;
  esac
done

FLAG_NAME="$1"
FLAG="$HOME/.local/state/dotfiles/toggles/hypr/$FLAG_NAME.conf"
FLAG_SOURCE="$HOME/dotfiles/hypr/toggles/$FLAG_NAME.conf"
mkdir -p "$(dirname "$FLAG")"

if [[ -f $FLAG ]]; then
  rm $FLAG
  [[ -n $DISABLED_NOTIFICATION ]] && notify-send -u low "$DISABLED_NOTIFICATION"
elif [[ -f $FLAG_SOURCE ]]; then
  cp $FLAG_SOURCE $FLAG
  [[ -n $ENABLED_NOTIFICATION ]] && notify-send -u low "$ENABLED_NOTIFICATION"
else
  echo "Flag not found: $FLAG_NAME"
  exit 1
fi

hyprctl reload
