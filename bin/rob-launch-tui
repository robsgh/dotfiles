#!/bin/bash

# Ensure sibling rob-* helpers resolve when launched by Hyprland without shell PATH updates.
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
export PATH="$script_dir:$PATH"

# Desktop:summary=Launch a TUI command in the default terminal with Desktop styling
# Desktop:args=<command> [args...]

exec setsid uwsm-app -- xdg-terminal-exec --app-id=org.rob.$(basename $1) -e "$1" "${@:2}"
