#!/bin/bash

# Ensure sibling rob-* helpers resolve when launched by Hyprland without shell PATH updates.
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
export PATH="$script_dir:$PATH"

# Desktop:summary=Send universal copy, paste, or cut shortcut and show swayosd feedback.
# Desktop:args=[copy|paste|cut]

case "${1:-}" in
  copy)
    hyprctl dispatch sendshortcut "CTRL, Insert, activewindow" >/dev/null
    rob-osd --custom-icon edit-copy-symbolic --custom-message "Copied"
    ;;
  paste)
    hyprctl dispatch sendshortcut "SHIFT, Insert, activewindow" >/dev/null
    rob-osd --custom-icon edit-paste-symbolic --custom-message "Pasted"
    ;;
  cut)
    hyprctl dispatch sendshortcut "CTRL, X, activewindow" >/dev/null
    rob-osd --custom-icon edit-cut-symbolic --custom-message "Cut"
    ;;
  *)
    echo "Usage: rob-clipboard-shortcut [copy|paste|cut]" >&2
    exit 2
    ;;
esac
