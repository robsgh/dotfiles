#!/bin/bash

# Ensure sibling rob-* helpers resolve when launched by Hyprland without shell PATH updates.
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
export PATH="$script_dir:$PATH"

# Desktop:summary=Launch the Desktop wifi controls (provided by the Impala TUI).

rfkill unblock wifi
rob-launch-or-focus-tui impala
