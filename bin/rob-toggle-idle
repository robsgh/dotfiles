#!/bin/bash

# Ensure sibling rob-* helpers resolve when launched by Hyprland without shell PATH updates.
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
export PATH="$script_dir:$PATH"

# Desktop:summary=Toggle hypridle idle locking

if pgrep -x hypridle >/dev/null; then
  pkill -x hypridle
  notify-send -u low "󱫖    Stop locking computer when idle"
else
  uwsm-app -- hypridle >/dev/null 2>&1 &
  notify-send -u low "󱫖    Now locking computer when idle"
fi

pkill -RTMIN+9 waybar
