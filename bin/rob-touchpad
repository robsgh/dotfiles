#!/bin/bash

# Ensure sibling rob-* helpers resolve when launched by Hyprland without shell PATH updates.
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
export PATH="$script_dir:$PATH"

# Desktop:summary=Enable, disable, or toggle the touchpad
# Desktop:args=[on|off|toggle]

STATE_CONF="$HOME/.local/state/dotfiles/toggles/hypr/touchpad-disabled.conf"

device="$(rob-touchpad-device)"

if [[ -z $device ]]; then
  echo "No touchpad device found" >&2
  exit 1
fi

enable() {
  hyprctl keyword "device[$device]:enabled" true >/dev/null
  rm -f "$STATE_CONF"
  rob-osd --custom-icon input-touchpad-symbolic --custom-message "Touchpad enabled"
}

disable() {
  hyprctl keyword "device[$device]:enabled" false >/dev/null
  mkdir -p "$(dirname "$STATE_CONF")"
  printf 'device {\n    name = %s\n    enabled = false\n}\n' "$device" > "$STATE_CONF"
  rob-osd --custom-icon touchpad-disabled-symbolic --custom-message "Touchpad disabled"
}

case "${1:-toggle}" in
  on) enable ;;
  off) disable ;;
  toggle) if [[ -f $STATE_CONF ]]; then enable; else disable; fi ;;
esac
