anchor=top-right
group-by=app-name,summary,body
default-timeout=5000
width=420
outer-margin=20
padding=10,15
border-size=2
border-radius=3
max-icon-size=32
font=sans-serif 14px

text-color=#bebebe
border-color=#e68e0d
background-color=#121212

[app-name=Spotify]
invisible=1

[mode=do-not-disturb]
invisible=true

[mode=do-not-disturb app-name=notify-send]
invisible=false

[urgency=critical]
default-timeout=0
layer=overlay

[summary~="Screenshot saved to clipboard and file"]
max-icon-size=80
format=<b>%s</b>\n%b

[app-name=Codex urgency=critical]
default-timeout=5000
